rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return isSignedIn() && request.auth.token.email == 'pierre.santos.p@gmail.com';
    }

    function isValidItem(data) {
      return data.keys().hasAll(['title', 'category', 'images', 'availability']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.category is string && data.category.size() <= 100 &&
             data.images is list && data.images.size() > 0 && data.images.size() <= 10 &&
             data.availability in ['Pronta Entrega', 'Sob Encomenda', 'Vendido'] &&
             (!data.keys().hasAny(['price']) || (data.price is string && data.price.size() <= 50)) &&
             (!data.keys().hasAny(['desc']) || (data.desc is string && data.desc.size() <= 2000));
    }

    match /collections/{itemId} {
      allow read: if true;
      allow create: if isOwner() && isValidItem(request.resource.data);
      allow update: if isOwner() && isValidItem(request.resource.data);
      allow delete: if isOwner();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}

service firebase.storage {
  match /b/{bucket}/o {
    // Default deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Catálogo público de leitura, escrita só da proprietária
    match /collections/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == 'pierre.santos.p@gmail.com'
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
