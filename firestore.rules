rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function isValidItem(data) {
      return data.keys().hasAll(['id', 'title', 'category', 'images', 'availability']) &&
             data.title is string && data.title.size() <= 200 &&
             data.category is string &&
             data.images is list && data.images.size() <= 10 &&
             data.availability in ['Pronta Entrega', 'Sob Encomenda', 'Vendido'];
    }

    function isOwner() {
      return isSignedIn() && request.auth.token.email == 'pierre.santos.p@gmail.com';
    }

    match /collections/{itemId} {
      allow read: if true;
      allow write: if isOwner(); 
    }

    match /test/connection {
      allow read: if true;
    }
  }
}

service firebase.storage {
  match /b/{bucket}/o {
    match /collections/{allPaths=**} {
      allow read: if true;
      allow write: if true; // Temporarily public for setup period
    }
  }
}
